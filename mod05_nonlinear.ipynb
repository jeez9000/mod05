#Updated Code for the Jupyter Notebook

import pandas as pd
import numpy as np
import statsmodels.api as sm

# Load the dataset
# Assuming the dataset is named 'data.csv' and includes necessary columns

data = pd.read_csv('data.csv')

# Feature engineering: creating additional features

data['atemp2'] = data['atemp']**2  # Square of atemp

data['temp_hum_interaction'] = data['temp'] * data['humidity']  # Interaction term

# Convert categorical variables to dummy/indicator variables
season_dummies = pd.get_dummies(data['season'], prefix='season')
weather_dummies = pd.get_dummies(data['weather'], prefix='weather')

# Concatenate the new dummy variables to the original dataframe
data = pd.concat([data, season_dummies, weather_dummies], axis=1)

# Defining the independent variables (features) for the regression model
# Including atemp2 and temp_hum_interaction features along with dummies
X = data[['atemp', 'atemp2', 'temp', 'humidity', 'temp_hum_interaction']+list(season_dummies.columns)+list(weather_dummies.columns)]
X = sm.add_constant(X) # Adds a constant term to the predictor

# Defining the dependent variable (target)
Y = data['target_variable']  # Replace 'target_variable' with the actual target column name

# Fitting the OLS model
model = sm.OLS(Y, X).fit()

# Print out the summary of the regression
print(model.summary())

# Model predictions
predictions = model.predict(X)  # Obtaining predictions

# Save the updated data and model predictions (if necessary)
data['predictions'] = predictions  # Optionally, save predictions back to the dataframe

